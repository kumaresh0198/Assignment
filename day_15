1. Navigate to https://www.globalsqa.com/demo-site/draganddrop/
 Dragndrop the images from "Photo Manager" to "Trash" also include a logic in ur script to ensure that the dropped item added to the trash.


package day_5;

import java.time.Duration;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.interactions.Actions;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class assignment {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		String url ="https://www.globalsqa.com/demo-site/draganddrop/";
		WebDriver driver = new ChromeDriver();
		driver.manage().window().maximize();	
		driver.get(url);
		
		/*
		 * here the photo manager is in iframe is to move to iframe we are finding
		 * locator of this iframe demo-frame has many suggestions with help of the parent
		 * div we can easily locate it and move to that iframe
		 */
		
		WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(10));
		wait.until(ExpectedConditions.frameToBeAvailableAndSwitchToIt(By.xpath("//div[contains(@class,'resp-tab-content-active')]//iframe[@class='demo-frame']")));
		
		// creating list for storing images locations and drop location
		List<WebElement> images = driver.findElements(By.className("ui-corner-tr"));
		WebElement dst = driver.findElement(By.xpath("//div[@id='trash']"));
		List<WebElement> txts = driver.findElements(By.xpath("//h5[@class='ui-widget-header']"));
        // Defining Action class.
		Actions mouseaction = new Actions(driver);		
		// creating a loop to drag and drop the image
		for(int i =0;i<images.size();i++) {
			
			WebElement image = images.get(i);
			WebElement txt   = txts.get(i);
			
			mouseaction.dragAndDrop(image, dst).perform();
			System.out.println(txt.getText() + " is moved to trash");
		}
		
		driver.close();
	}

}


2. Navigate to https://www.globalsqa.com/
    Mouse hover on "Free EBooks" and then select "Free Machine Learning Ebooks"

package day_5;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.interactions.Actions;

public class assignment_2 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		String url ="https://www.globalsqa.com/";
		WebDriver driver = new ChromeDriver();
		driver.manage().window().maximize();	
		driver.get(url);
		// Hover on Free EBooks
		WebElement free_books = driver.findElement(By.xpath("(//a[@class='no_border'])[1]"));
		Actions mouseaction = new Actions(driver);
		mouseaction.moveToElement(free_books).perform();
		// Click Free Machine Learning Ebooks
		WebElement mlbooks = driver.findElement(By.id("menu-item-7132"));
		mouseaction.click(mlbooks).perform();
		
		driver.close();
	}

}
